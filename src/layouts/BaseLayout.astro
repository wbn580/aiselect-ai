---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "AI Select",
        "url": "https://aiselect.ai",
        "description": "AI tools, reviewed honestly. Hands-on testing, transparent ratings, affiliate-disclosed verdicts.",
        "inLanguage": "en"
      })}
    </script>
  </head>
  <body class="font-sans text-[#0F0F1B] bg-white antialiased min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
