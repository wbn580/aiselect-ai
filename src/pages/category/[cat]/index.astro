---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("articles");
  const cats = new Set();
  for (const p of posts) {
    if (p.data.category) cats.add(p.data.category);
  }
  return [...cats].map(cat => ({
    params: { cat: cat.toLowerCase().replace(/ /g, '-') },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const posts = (await getCollection("articles")).filter(p => {
  const pc = p.data.category;
  return pc && pc.toLowerCase().replace(/ /g, '-') === cat;
});
---
<BaseLayout title={`Category: ${cat}`}>
  <main class="max-w-3xl mx-auto p-8">
    <h1 class="text-2xl font-bold mb-4">Category: {cat}</h1>
    {posts.length === 0 && <p>No posts in this category yet.</p>}
    <ul>
      {posts.map(p => (
        <li><a href={`/posts/${p.id.split('/').pop()}/`}>{p.data.title}</a></li>
      ))}
    </ul>
  </main>
</BaseLayout>
