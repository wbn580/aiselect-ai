---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — AI Select" description="Page not found.">
  <div class="max-w-[42rem] mx-auto px-6 py-32 text-center">
    <span class="font-mono text-5xl text-[#00D9C0] font-bold tabular-nums">404</span>
    <h1 class="mt-4 text-2xl font-mono font-bold">Page not found</h1>
    <p class="mt-3 text-[#6B7280] max-w-sm mx-auto">The tool you're looking for isn't in our directory. Try the <a href="/" class="text-[#00D9C0] hover:underline">homepage</a>.</p>
  </div>
</BaseLayout>
