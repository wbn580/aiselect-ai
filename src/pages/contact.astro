---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact AI Select" description="Contact the AI Select editorial team.">
  <div class="max-w-[42rem] mx-auto px-6 py-16">
    <h1 class="text-3xl font-mono font-bold mb-8">Contact AI Select</h1>
    <div class="space-y-5 text-[#0F0F1B] leading-relaxed
      [&_h2]:text-xl [&_h2]:font-mono [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4
      [&_h2]:pb-2 [&_h2]:border-b [&_h2]:border-gray-100
      [&_a]:text-[#00B8A2] hover:[&_a]:underline
    ">
      <p class="text-lg text-[#6B7280]">Questions, corrections, partnership enquiries, or feedback are welcome.</p>

      <h2>Email</h2>
      <p><a href="mailto:contact@aiselect.ai">contact@aiselect.ai</a></p>

      <h2>Publisher</h2>
      <p>AI Select is operated by Arrivau Pty Ltd in Australia and published under the Selector Labs editorial label.</p>

      <h2>Editorial corrections</h2>
      <p>Please include the page URL and a short description of the issue. We review substantiated corrections and update material errors as soon as practicable.</p>
    </div>
  </div>
</BaseLayout>
