---
import { codexReferral } from '../config/referrals';

interface Props {
  placement: string;
  compact?: boolean;
}

const { placement, compact = false } = Astro.props;
const href = `${codexReferral.href}?p=${encodeURIComponent(`aiselect.ai/${placement}`)}`;
---

{codexReferral.enabled && (
  <aside class:list={['codex-referral', { 'codex-referral--compact': compact }]} aria-label="Codex referral invitation">
    <div class="codex-referral__mark" aria-hidden="true">&lt;/&gt;</div>
    <div class="codex-referral__copy">
      <span class="codex-referral__eyebrow">Official referral invitation</span>
      <h2>Try Codex on a real project</h2>
      <p>
        OpenAI determines who qualifies and what benefit applies. Use the official invitation flow—no account sharing, aliases or self-referrals.
      </p>
    </div>
    <a
      class="codex-referral__action"
      href={href}
      target="_blank"
      rel="sponsored nofollow noopener noreferrer"
      data-cta="codex-referral"
    >
      View invitation <span aria-hidden="true">↗</span>
    </a>
  </aside>
)}

<style>
  .codex-referral {
    --ref-accent: #00d9c0;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 18px;
    max-width: 72rem;
    margin: 2.5rem auto;
    padding: 22px 24px;
    border: 1px solid color-mix(in srgb, var(--ref-accent) 35%, #d8dde6);
    border-radius: 18px;
    background:
      linear-gradient(130deg, color-mix(in srgb, var(--ref-accent) 8%, #fff), #fff 52%, color-mix(in srgb, var(--ref-accent) 5%, #fff));
    box-shadow: 0 24px 64px -48px rgba(15, 15, 27, 0.65);
  }
  .codex-referral__mark {
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border-radius: 15px;
    background: #1a1a2e;
    color: var(--ref-accent);
    font: 800 15px/1 "JetBrains Mono", monospace;
    box-shadow: 0 16px 28px -20px #1a1a2e;
  }
  .codex-referral__eyebrow {
    display: block;
    margin-bottom: 5px;
    color: #008f80;
    font: 700 11px/1.2 "JetBrains Mono", monospace;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .codex-referral h2 {
    margin: 0;
    color: #0f0f1b;
    font: 700 18px/1.3 "JetBrains Mono", monospace;
  }
  .codex-referral p {
    margin: 7px 0 0;
    color: #596170;
    font-size: 14px;
    line-height: 1.55;
  }
  .codex-referral__action {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 0 18px;
    border-radius: 999px;
    background: #1a1a2e;
    color: #fff;
    font: 700 13px/1 "JetBrains Mono", monospace;
    text-decoration: none;
    white-space: nowrap;
    transition: transform .18s ease, background-color .18s ease, box-shadow .18s ease;
  }
  .codex-referral__action:hover,
  .codex-referral__action:focus-visible {
    background: #252541;
    box-shadow: 0 14px 28px -20px #1a1a2e;
    transform: translateY(-1px);
    outline: 2px solid color-mix(in srgb, var(--ref-accent) 70%, transparent);
    outline-offset: 3px;
  }
  .codex-referral--compact {
    margin: 2.75rem 0 1rem;
    padding: 18px;
  }
  .codex-referral--compact .codex-referral__mark {
    width: 46px;
    height: 46px;
  }
  @media (max-width: 720px) {
    .codex-referral {
      grid-template-columns: auto minmax(0, 1fr);
      padding: 18px;
      gap: 14px;
    }
    .codex-referral__action {
      grid-column: 1 / -1;
      width: 100%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .codex-referral__action { transition: none; }
  }
</style>
