---
const links = [
  ['Tools', '/'],
  ['Compare', '/'],
  ['Methodology', '/methodology/'],
  ['About', '/about/'],
];
---

<header class="sticky top-0 z-50 bg-[#1A1A2E]/95 backdrop-blur-sm border-b border-white/[0.06]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center h-16 gap-10">
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="w-7 h-7 rounded-md bg-[#00D9C0]/15 flex items-center justify-center">
          <span class="text-[#00D9C0] text-sm font-mono font-bold">&gt;_</span>
        </span>
        <span class="font-mono font-bold text-base text-white tracking-tight">aiselect</span>
      </a>
      <nav class="hidden xl:flex gap-8">
        {links.map(([label, href]) => (
          <a href={href} class="text-sm text-gray-400 hover:text-white transition-colors font-medium">{label}</a>
        ))}
      </nav>
    </div>
  </div>
</header>

<style>


  /* MENU-CROWD-FIX-20260708: keep dense desktop menus from wrapping or crushing CTA buttons. */
  header nav a,
  .nav-links a,
  .nav-link,
  .nav-cta,
  .site-nav a {
    white-space: nowrap;
  }
  .nav-links,
  .site-nav {
    min-width: 0;
  }
  .site-nav.flex-wrap,
  nav.site-nav.flex-wrap {
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .site-nav.flex-wrap::-webkit-scrollbar,
  nav.site-nav.flex-wrap::-webkit-scrollbar {
    display: none;
  }
</style>
